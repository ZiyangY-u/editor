% Cartesian coordinate system
\NewDocumentCommand\ccs{mmmm s} { % -x, x, -y, y, grid-opt
  % Draw the x-axis
  \draw[->] (#1,0) -- (#2,0) node[right] {$x$};
  % Draw the y-axis
  \draw[->] (0,#3) -- (0,#4) node[above] {$y$};

  % Optionally, add labels for specific points or tick marks
  \foreach \x in {#1,...,-1}
  \draw (\x,0.1) -- (\x,-0.1) node[below] {\x};
  \foreach \x in {1,...,#2}
  \draw (\x,0.1) -- (\x,-0.1) node[below] {\x};
  \foreach \y in {#3,...,-1}
  \draw (0.1,\y) -- (-0.1,\y) node[left] {\y};
  \foreach \y in {1,...,#4}
  \draw (0.1,\y) -- (-0.1,\y) node[left] {\y};

  % Mark the origin
  \fill (0,0) circle (1.5pt) node[below left] {$O$};

  % Optionally, add a grid
  \IfBooleanT{#5}
  {
    \draw[help lines, dashed, gray] (#1 + .5,#3 + .5) grid (#2 - .5,#4 - .5);
    % \draw[help lines, dashed, gray] (#1, #3) grid (#2, #4);
  }
}

