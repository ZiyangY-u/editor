snippet 0 "$0" w
\$0
endsnippet

snippet 1 "$1" w
\$1
endsnippet

snippet 2 "$2" w
\$2
endsnippet

snippet 3 "$3" w
\$3
endsnippet

snippet 4 "$4" w
\$4
endsnippet

snippet 5 "$5" w
\$5
endsnippet

snippet or "or" w
||
endsnippet

snippet and "and" w
&&
endsnippet

snippet p "print" w
print $0
endsnippet
snippet pf "printf" w
printf "$0"
endsnippet
