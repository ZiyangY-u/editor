snippet recovery "description" w
USE [$1]

 -- 1гЂЃгѓђгѓѓг‚Їг‚ўгѓѓгѓ—гѓ†гѓјгѓ–гѓ«дЅњж€ђе…Ёд»¶г‚ігѓ”гѓјгЃ™г‚‹
SELECT * INTO WKDB.DBO.`!v getreg('"')`_BAK_`date +%Y%m%d`_1 FROM $1.DBO.`!v getreg('"')`
SELECT * INTO WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1 FROM $1.DBO.`!v getreg('"')`
ALTER TABLE WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1 ADD R_DATE smalldatetime, U_FLAG smallint
SELECT '`!v getreg('"')`', COUNT(1) FROM $1.DBO.`!v getreg('"')` union all
SELECT '`!v getreg('"')`_BAK_`date +%Y%m%d`_1', COUNT(1) FROM WKDB.DBO.`!v getreg('"')`_BAK_`date +%Y%m%d`_1 union all
SELECT '`!v getreg('"')`_WK_`date +%Y%m%d`_1', COUNT(1) FROM WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1
 -- е•ЏйЎЊгЃЊгЃ‚г‚‹гѓ‡гѓјг‚їг‚’е•ЏгЃ„еђ€г‚ЏгЃ›
 -- пј’гЂЃгѓ‡гѓјг‚їгѓЄг‚«гѓђгѓЄгѓјпј€гѓЇгѓјг‚Їгѓ†гѓјгѓ–гѓ«пј‰
 -- гѓЇгѓјг‚Їгѓ†гѓјгѓ–гѓ«ж›ґж–°е‰ЌгѓЃг‚§гѓѓг‚Ї
SELECT
...
FROM WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1 A
...
 -- гѓЇгѓјг‚Їгѓ†гѓјгѓ–гѓ«ж›ґж–°
UPDATE A
SET ...
, A.U_FLAG = 1
, A.R_DATE = getdate()
, A.UPDATE_USER_ID = 8837
, A.UPDATE_DATE_TIME = getdate()
FROM WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1 A
...
 -- пј“гЂЃгѓ‡гѓјг‚їгѓЄг‚«гѓђгѓЄгѓјпј€жњ¬з•Єгѓ†гѓјгѓ–гѓ«пј‰
 -- жњ¬з•Єгѓ†гѓјгѓ–гѓ«ж›ґж–°е‰ЌгѓЃг‚§гѓѓг‚Ї
SELECT
...
, A.UPDATE_USER_ID
, A.UPDATE_DATE_TIME
FROM $1.DBO.`!v getreg('"')` B,
    WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1 A
WHERE A.U_FLAG = 1
AND A.$2 = B.$2
AND A.$3 = B.$3
AND A.$4 = B.$4

 -- жњ¬з•Єгѓ†гѓјгѓ–гѓ«ж›ґж–°
UPDATE B
SET
...
, B.UPDATE_USER_ID = A.UPDATE_USER_ID
, B.UPDATE_DATE_TIME = A.UPDATE_DATE_TIME
FROM $1.DBO.`!v getreg('"')` B,
    WKDB.DBO.`!v getreg('"')`_WK_`date +%Y%m%d`_1 A
WHERE A.U_FLAG = 1
AND A.$2 = B.$2
AND A.$3 = B.$3
AND A.$4 = B.$4
endsnippet

