snippet test "description" w
`!p snip.basename`
endsnippet

snippet wow
${1:Text}`!p snip.rv = (75-2*len(t[1]))*' '+t[1].upper()`
endsnippet

snippet cp "description" w
 `!v getreg('"')`
endsnippet

snippet t "tab indente" w
	`!v getreg('"')`
endsnippet

