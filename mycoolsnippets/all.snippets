snippet s "The snippet snippet" w
snippet $1 "$2" w
$0
`echo endsnippet`
endsnippet

snippet r "vim register" w
\`!v getreg('"')\`
endsnippet

snippet sync
sync `date +%Y/%m/%d`.
endsnippet

snippet time "date time" w
`date +%Y.%m.%d-%H:%M:%S`
endsnippet
snippet date "date" w
`date +%Y.%m.%d`
endsnippet

snippet ( "()" "not re.match('\)', vim.eval('getline(\'.\')[col(\'.\')-1]'))" ie
(${VISUAL}$0)
endsnippet
snippet < "<>" "not re.match('\>', vim.eval('getline(\'.\')[col(\'.\')-1]'))" ie
<${VISUAL}$0>
endsnippet
snippet [ "[]" "not re.match('\]', vim.eval('getline(\'.\')[col(\'.\')-1]'))" ie
[${VISUAL}$0]
endsnippet
snippet { "{}" "not re.match('\}', vim.eval('getline(\'.\')[col(\'.\')-1]'))" ie
{${VISUAL}$0}
endsnippet
snippet ' "quotation" "not re.match('\'', vim.eval('getline(\'.\')[col(\'.\')-1]'))" ie
'${VISUAL}$0'
endsnippet
snippet " "quotation" "not re.match('\u0022', vim.eval('getline(\'.\')[col(\'.\')-1]'))" ie
"${VISUAL}$0"
endsnippet

snippet , "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
、
endsnippet
snippet . "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
。
endsnippet
snippet / "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
・
endsnippet
snippet ? "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
？
endsnippet
snippet ! "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
！
endsnippet
snippet : "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
：
endsnippet
snippet ; "jp-ime" "re.match('1', vim.eval('g:jpIme'))" ie
；
endsnippet
snippet [ "jp-ime brackets shikaku" "re.match('1', vim.eval('g:jpIme'))" ie
「${VISUAL}$0」
endsnippet
snippet ( "jp-ime brackets maru" "re.match('1', vim.eval('g:jpIme'))" ie
（${VISUAL}$0）
endsnippet
snippet , "cn-ime 逗号" "re.match('1', vim.eval('g:cnIme'))" ie
，
endsnippet
snippet . "cn-ime 句号" "re.match('1', vim.eval('g:cnIme'))" ie
。
endsnippet
snippet ; "cn-ime 分号" "re.match('1', vim.eval('g:cnIme'))" ie
；
endsnippet
snippet : "cn-ime 冒号" "re.match('1', vim.eval('g:cnIme'))" ie
：
endsnippet
snippet ' "cn-ime 单引号" "re.match('1', vim.eval('g:cnIme'))" ie
‘${VISUAL}$0’
endsnippet
snippet " "cn-ime 双引号" "re.match('1', vim.eval('g:cnIme'))" ie
“${VISUAL}$0”
endsnippet
snippet ? "cn-ime 问号" "re.match('1', vim.eval('g:cnIme'))" ie
？
endsnippet
snippet ! "cn-ime 感叹号" "re.match('1', vim.eval('g:cnIme'))" ie
！
endsnippet
snippet < "cn-ime bookmark 双书名号" "re.match('1', vim.eval('g:cnIme'))" ie
《${VISUAL}$0》
endsnippet
snippet \ "cn-ime 顿号" "re.match('1', vim.eval('g:cnIme'))" ie
、
endsnippet
snippet [ "cn-ime bracket 双括号" "re.match('1', vim.eval('g:cnIme'))" ie
【${VISUAL}$0】
endsnippet
